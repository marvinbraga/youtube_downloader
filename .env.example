# ==============================================================================
# YouTube Downloader — Environment Variables Example
# Copy this file to .env and fill in your values.
# ==============================================================================

# ==============================================================================
# APPLICATION SECURITY
# ==============================================================================

# JWT secret key — use a strong random string (e.g. openssl rand -hex 32)
SECRET_KEY=your_secret_key_here

# Authorized API clients (client_id:client_secret pairs, comma-separated)
# AUTHORIZED_CLIENTS=client_id_1:client_secret_1,client_id_2:client_secret_2

# ==============================================================================
# LLM API KEYS (for transcription features)
# ==============================================================================

ANTHROPIC_API_KEY=sk-ant-...
COHERE_API_KEY=
GOOGLE_API_KEY=
GROQ_API_KEY=gsk_...
NVIDIA_API_KEY=nvapi-...
OPENAI_API_KEY=sk-...
XAI_API_KEY=xai-...

# ==============================================================================
# YOUTUBE COOKIE AUTHENTICATION (optional)
# Use one of the two options below to authenticate downloads with your
# YouTube account (required for age-restricted, members-only, or private videos).
# ==============================================================================

# Option 1 — Use cookies from a browser profile (recommended for local use).
# The browser must be CLOSED when the server starts.
# Supported values: chrome, brave, firefox, edge, opera, safari, vivaldi
# YT_COOKIES_FROM_BROWSER=chrome

# Option 2 — Use a cookies.txt file in Netscape format.
# Export from your browser with the "Get cookies.txt LOCALLY" extension.
# Must be an absolute path to an existing regular file.
# YT_COOKIES_FILE=/home/user/cookies.txt

# Note: YT_COOKIES_FROM_BROWSER takes precedence over YT_COOKIES_FILE.
# Leave both unset to download without authentication.

# ==============================================================================
# INSTAGRAM COOKIE AUTHENTICATION (optional)
# Public Reels/Posts work without cookies. Provide cookies only if you need
# to access private/login-walled content.
# ==============================================================================

# Same options as YouTube — pick one prefix per source.
# INSTAGRAM_COOKIES_FROM_BROWSER=chrome
# INSTAGRAM_COOKIES_FILE=/app/cookies/instagram.txt

# ==============================================================================
# DOCKER DEPLOYMENT (optional)
# ==============================================================================

# Host port to expose the container on (container always listens on 8000).
# APP_PORT=8000

# ==============================================================================
# YT-DLP DEBUG (optional)
# ==============================================================================

# Set to "1" to enable verbose yt-dlp output (WARNING: may log cookie data).
# YT_DLP_VERBOSE=1
